---
import config from "@/config/config.json";
const { src } = Astro.props;
const {
  logo,
  logo_width,
  logo_height,
  logo_text,
  title,
}: {
  logo: string;
  logo_width: any;
  logo_height: any;
  logo_text: string;
  title: string;
} = config.site;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const logoSrc = src || logo;
---

<a href={import.meta.env.BASE_URL} class="navbar-brand block">
  {
    logoSrc ? (
      <img
        src={`${base}${logoSrc}`}
        alt={title}
        loading="lazy"
        decoding="async"
        width={logo_width.replace("px", "") * 2}
        height={logo_height.replace("px", "") * 2}
        style={`height:${logo_height.replace("px", "")}px;width:${logo_width.replace("px", "")}px`}
      />
    ) : logo_text ? (
      logo_text
    ) : (
      title
    )
  }
</a>
